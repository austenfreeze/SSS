    "@sanity/vision": "^5.12.0",
    "aframe": "^1.7.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "sanity": "^5.12.0",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.1.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "styled-components": "$styled-components"
